# Local testing and GraphQL code generation only.
#
# Copy this file to `.env` before running `pnpm run execute:*` or
# `pnpm run codegen`. Pulumi deployments do not read this file; configure
# deployment values with `pulumi config` for each stack instead.

# Required by every `pnpm run execute:*` command.
WEBHOOK_URL="CHANGEME"

# Required by `pnpm run codegen` and execute commands that query The Graph
# network (events, heartbeats, snapshots, target price, YRF, and Emission Manager).
GRAPHQL_API_KEY="CHANGEME"

# Required by `pnpm run codegen` and Convertible Deposits execute commands:
# failed periodic tasks, bond market creation failed, auction parameters,
# auction result, and claimed yield.
CONVERTIBLE_DEPOSITS_SUBGRAPH_URL="CHANGEME"

# Required only by `pnpm run execute:auctionparametersupdated`.
# The endpoint must support historical `eth_call` requests at the event block.
ETHEREUM_RPC_URL="CHANGEME"

# Optional variables
# None are currently consumed from `.env`.
