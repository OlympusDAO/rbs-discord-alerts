{
  "name": "rbs-discord-alerts",
  "main": "index.ts",
  "scripts": {
    "execute:events": "node --env-file=.env -r ts-node/register src/handlePriceEvents.ts",
    "execute:heartbeats": "node --env-file=.env -r ts-node/register src/handleHeartbeat.ts",
    "execute:snapshots": "node --env-file=.env -r ts-node/register src/handleSnapshotCheck.ts",
    "execute:targetPrice": "node --env-file=.env -r ts-node/register src/handleTargetPriceChangedEvents.ts",
    "execute:yrfmarkets": "node --env-file=.env -r ts-node/register src/handleYRFMarkets.ts",
    "execute:emissionmanagermarkets": "node --env-file=.env -r ts-node/register src/handleEmissionManagerMarkets.ts",
    "execute:failedperiodictasks": "node --env-file=.env -r ts-node/register src/handleFailedPeriodicTasks.ts",
    "execute:bondmarketcreationfailed": "node --env-file=.env -r ts-node/register src/handleBondMarketCreationFailed.ts",
    "execute:auctionparametersupdated": "node --env-file=.env -r ts-node/register src/handleAuctionParametersUpdated.ts",
    "execute:auctionresult": "node --env-file=.env -r ts-node/register src/handleAuctionResult.ts",
    "execute:claimedyield": "node --env-file=.env -r ts-node/register src/handleClaimedYield.ts",
    "codegen": "node --env-file=.env node_modules/.bin/graphql-codegen",
    "build": "tsc",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "deploy:dev": "pulumi up --stack dev",
    "deploy:prod": "pulumi up --stack prod"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@graphql-codegen/cli": "^2.12.2",
    "@graphql-codegen/typed-document-node": "^2.3.3",
    "@graphql-codegen/typescript": "^2.7.3",
    "@graphql-codegen/typescript-operations": "^2.5.3",
    "@graphql-typed-document-node/core": "^3.1.1",
    "@pulumi/gcp": "^9.18.0",
    "@pulumi/pulumi": "^3.252.0",
    "@types/jest": "^29.2.3",
    "@types/node": "^22.0.0",
    "jest": "^29.3.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.0.0",
    "@urql/core": "^3.0.3",
    "@urql/exchange-retry": "~1.0.0",
    "cross-fetch": "^3.1.5",
    "dedent-js": "^1.0.1",
    "graphql": "^16.13.2"
  },
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11.0.0",
    "npm": "use-pnpm",
    "yarn": "use-pnpm"
  },
  "packageManager": "pnpm@11.13.0"
}
